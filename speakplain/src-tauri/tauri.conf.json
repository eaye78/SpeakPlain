{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "说人话",
  "version": "0.1.0",
  "identifier": "com.speakplain.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "说人话 - 设置",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      },
      {
        "label": "indicator",
        "title": "",
        "url": "#/indicator",
        "width": 400,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../models/**/*",
      "../skins/**/*"
    ]
  },
  "plugins": {}
}
